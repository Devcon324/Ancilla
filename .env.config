# Copy this file to .env and fill in your local values.
#   copy .env.config .env

# --- Required for full voice loop ---
PIPER_VOICE=D:\GitHub\jetson-nano-jarvis\models\piper\en\american\en_US-norman-medium.onnx
PIPER_BIN=D:\GitHub\jetson-nano-jarvis\.venv\Scripts\piper.exe
# Speaking cadence: <1.0 = faster/snappier, >1.0 = slower. 1.0 = model default.
PIPER_LENGTH_SCALE=1.0

# Wake word: built-in openWakeWord model (say "hey jarvis")
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.7
WAKE_WORD_CONSECUTIVE_HITS=4
WAKE_WORD_INTERRUPT_THRESHOLD=0.85
WAKE_WORD_INTERRUPT_GRACE_SECONDS=1.5
WAKE_WORD_POST_SPEECH_COOLDOWN_SECONDS=2.0
WAKE_WORD_PRE_RECORD_DELAY_SECONDS=0.15

# Recording — lower silence timeout = snappier end-of-speech detection
SILENCE_TIMEOUT_SECONDS=0.7
NO_SPEECH_TIMEOUT_SECONDS=3.0
MAX_RECORD_SECONDS=12

# --- Audio (leave blank for Windows defaults) ---
ASSISTANT_MIC_DEVICE=
ASSISTANT_SPEAKER_DEVICE=

# --- Local model servers (must match Jetson) ---
WHISPER_SERVER_URL=http://127.0.0.1:8080/inference
LLAMA_SERVER_URL=http://127.0.0.1:8081/v1/chat/completions
LLAMA_MODEL_NAME=qwen2.5-3b-instruct-q4_k_m

# --- Store hours (OpenStreetMap by default; uses home location from defaults.json) ---
# Initial search radius in km; expands automatically if nothing is found
STORE_SEARCH_RADIUS_KM=10
# Optional: Google Places for more accurate hours (requires billing on Google Cloud)
# GOOGLE_PLACES_API_KEY=

# --- Optional: music ---
NAVIDROME_URL=http://127.0.0.1:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# Location, timezone, assistant name, and units: edit defaults.json
# Optional overrides (normally leave blank):
# TIMEZONE=America/Toronto
# LOCATION_CITY=Ottawa
# LOCATION_PROVINCE_OR_STATE=ON
# LOCATION_COUNTRY=Canada
# WEATHER_LAT=45.4215
# DEFAULTS_FILE=defaults.json
