# Copy to .env and fill in your local values:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux / Jetson)
#
# Location, timezone, assistant name, and units live in config/defaults.json
# (copy config/defaults.example.json → config/defaults.json).

# --- Required for voice output ---
PIPER_VOICE=C:\path\to\voice.onnx
# After uv sync, piper may be at: .venv\Scripts\piper.exe
PIPER_BIN=piper
# Speaking cadence: <1.0 = faster, >1.0 = slower. 1.0 = model default.
PIPER_LENGTH_SCALE=1.0

# --- Wake word (say "hey jarvis") ---
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.7
WAKE_WORD_CONSECUTIVE_HITS=4
WAKE_WORD_INTERRUPT_THRESHOLD=0.85
WAKE_WORD_INTERRUPT_GRACE_SECONDS=1.5
# On with pause-and-confirm (STT must hear "jarvis") so BT speaker bleed is ignored.
ASSISTANT_BARGE_IN=true
# Sink volume when Jarvis starts (0–100).
ASSISTANT_STARTUP_VOLUME_PERCENT=10
WAKE_WORD_POST_SPEECH_COOLDOWN_SECONDS=2.0
WAKE_WORD_PRE_RECORD_DELAY_SECONDS=0.15

# --- Recording (lower silence timeout = snappier end-of-speech) ---
SILENCE_TIMEOUT_SECONDS=0.7
NO_SPEECH_TIMEOUT_SECONDS=3.0
MAX_RECORD_SECONDS=12

# --- Audio devices (blank = system default) ---
ASSISTANT_MIC_DEVICE=
ASSISTANT_SPEAKER_DEVICE=

# --- Local model servers ---
WHISPER_SERVER_URL=http://127.0.0.1:8080/inference
LLAMA_SERVER_URL=http://127.0.0.1:8081/v1/chat/completions
LLAMA_MODEL_NAME=qwen2.5-3b-instruct-q4_k_m

# --- Store hours (OpenStreetMap by default; home location in config/defaults.json) ---
STORE_SEARCH_RADIUS_KM=10
# Optional: Google Places for more accurate hours (requires billing on Google Cloud)
# GOOGLE_PLACES_API_KEY=

# --- Optional: music ---
# Self-hosted library (takes priority when user+pass are set):
NAVIDROME_URL=http://127.0.0.1:4533
NAVIDROME_USER=
NAVIDROME_PASS=
# Hobby YouTube via yt-dlp (src/.../youtube_music.py). false = disable / easy remove.
MUSIC_YOUTUBE_ENABLED=true
# Otherwise "play …" uses SomaFM (ad-free) or Radio Browser (open radio directory).
# Needs: sudo apt install mpv

# --- Diagnostics (0 = off) ---
RESOURCE_LOG_INTERVAL_SECONDS=30

# --- Optional env overrides (normally leave blank; config/defaults.json is preferred) ---
# DEFAULTS_FILE=config/defaults.json
# TIMEZONE=America/Toronto
# LOCATION_CITY=Ottawa
# LOCATION_PROVINCE_OR_STATE=Ontario
# LOCATION_COUNTRY=Canada
# WEATHER_LAT=45.4215
# WEATHER_LON=-75.6972
# WEATHER_LOCATION_NAME=Ottawa, ON
