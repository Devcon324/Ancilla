# Copy this file to .env and fill in your local values.
#   copy .env.config .env

# --- Required for full voice loop ---
PIPER_VOICE=C:\models\piper\en_US-lessac-medium.onnx
# After uv sync, piper-tts may provide: .venv\Scripts\piper.exe
PIPER_BIN=C:\path\to\piper.exe

# Wake word: built-in openWakeWord model (say "hey jarvis")
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# --- Audio (leave blank for Windows defaults) ---
ASSISTANT_MIC_DEVICE=
ASSISTANT_SPEAKER_DEVICE=

# --- Local model servers (must match Jetson) ---
WHISPER_SERVER_URL=http://127.0.0.1:8080/inference
LLAMA_SERVER_URL=http://127.0.0.1:8081/completion
LLAMA_MODEL_NAME=qwen2.5-3b-instruct-q4_k_m

# --- Optional: store hours ---
GOOGLE_PLACES_API_KEY=

# --- Optional: music ---
NAVIDROME_URL=http://127.0.0.1:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# --- Weather (defaults to Ottawa) ---
WEATHER_LAT=45.4215
WEATHER_LON=-75.6972
WEATHER_LOCATION_NAME=Ottawa, ON
